# watsonx.ai Configuration (REQUIRED)
# ⚠️  SECURITY WARNING: Never commit actual API keys to version control!
# ⚠️  Use environment-specific .env files and add .env to .gitignore
WATSONX_API_KEY=your_api_key_here
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Application Settings
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Storage Configuration
DATA_DIR=./data

# CORS Configuration (Issue #1 Fix)
# Comma-separated list of allowed origins
# Production: Set to your actual frontend domain(s)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Security Settings
# For production, consider using a secrets manager (AWS Secrets Manager, HashiCorp Vault, etc.)