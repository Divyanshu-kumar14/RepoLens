<content>/**
 * RepoLens - Main Page
 * Chat with Your Codebase
 */

'use client';

import { useState } from 'react';
import RepoInput from '@/components/RepoInput';
import ChatBox from '@/components/ChatBox';
import MessageList from '@/components/MessageList';
import { apiService } from '@/services/api';
import { Message } from '@/types/api';

export default function Home() {
  const [currentRepoId, setCurrentRepoId] = useState<string | null>(null);
  const [messages, setMessages] = useState<Message[]>([]);
  const [isQuerying, setIsQuerying] = useState(false);
  const [error, setError] = useState<string | null>(null);

  // Handle successful repository ingestion
  const handleIngestionComplete = (repoId: string) => {
    setCurrentRepoId(repoId);
    setMessages([]);
    setError(null);
  };

  // Handle sending a question
  const handleSendMessage = async (question: string) => {
    if (!currentRepoId) {
      setError('Please ingest a repository first');
      return;
    }

    // Add user message
    const userMessage: Message = {
      id: `user-${Date.now()}`,
      type: 'user',
      content: question,
      timestamp: new Date(),
    };
    setMessages((prev) => [...prev, userMessage]);
    setError(null);
    setIsQuerying(true);

    try {
      // Query the repository
      const response = await apiService.queryRepository(currentRepoId, question);

      // Add assistant message
      const assistantMessage: Message = {
        id: `assistant-${Date.now()}`,
        type: 'assistant',
        content: response.answer,
        sources: response.sources,
        timestamp: new Date(),
      };
      setMessages((prev) => [...prev, assistantMessage]);
    } catch (err: any) {
      setError(err.response?.data?.detail || err.message || 'Failed to get answer');
      
      // Add error message
      const errorMessage: Message = {
        id: `error-${Date.now()}`,
        type: 'assistant',
        content: `Sorry, I encountered an error: ${err.response?.data?.detail || err.message || 'Unknown error'}`,
        timestamp: new Date(),
      };
      setMessages((prev) => [...prev, errorMessage]);
    } finally {
      setIsQuerying(false);
    }
  };

  return (
    <main className="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100 py-8 px-4">
      <div className="max-w-6xl mx-auto space-y-8">
        {/* Header */}
        <header className="text-center">
          <h1 className="text-4xl font-bold text-gray-900 mb-2">
            🔍 RepoLens
          </h1>
          <p className="text-gray-600">
            Chat with Your Codebase - Powered by watsonx.ai Granite
          </p>
        </header>

        {/* Repository Input Section */}
        <section>
          <RepoInput onIngestionComplete={handleIngestionComplete} />
        </section>

        {/* Chat Section */}
        {currentRepoId && (
          <section className="space-y-4">
            {/* Chat Messages */}
            <div className="bg-white rounded-lg shadow-lg p-4">
              <h2 className="text-xl font-semibold text-gray-800 mb-4">
                Chat
              </h2>
              <MessageList messages={messages} />
            </div>

            {/* Error Display */}
            {error && (
              <div className="p-3 bg-red-50 border border-red-200 rounded-lg">
                <p className="text-red-700 text-sm">{error}</p>
              </div>
            )}

            {/* Chat Input */}
            <ChatBox
              onSendMessage={handleSendMessage}
              disabled={!currentRepoId}
              isLoading={isQuerying}
            />
          </section>
        )}

        {/* Instructions (shown when no repo is ingested) */}
        {!currentRepoId && (
          <section className="bg-white rounded-lg shadow-lg p-6">
            <h2 className="text-xl font-semibold text-gray-800 mb-4">
              How to Use RepoLens
            </h2>
            <ol className="list-decimal list-inside space-y-2 text-gray-700">
              <li>Enter a public GitHub repository URL above</li>
              <li>Click "Ingest" and wait for the repository to be processed</li>
              <li>Once complete, ask questions about the codebase</li>
              <li>Get AI-powered answers with source code references</li>
            </ol>
            
            <div className="mt-6 p-4 bg-blue-50 rounded-lg">
              <h3 className="font-semibold text-blue-900 mb-2">
                Example Questions:
              </h3>
              <ul className="list-disc list-inside space-y-1 text-blue-800 text-sm">
                <li>What does this repository do?</li>
                <li>How does the authentication work?</li>
                <li>Explain the main components of this project</li>
                <li>What dependencies does this project use?</li>
                <li>How is error handling implemented?</li>
              </ul>
            </div>
          </section>
        )}

        {/* Footer */}
        <footer className="text-center text-gray-600 text-sm">
          <p>
            Built with FastAPI, LangChain, watsonx.ai Granite, and ChromaDB
          </p>
        </footer>
      </div>
    </main>
  );
}
</content>
